{
  "nodes": [
    {
      "id": "optimizer",
      "type": "llm",
      "prompt": "Create a search query searching for jobs which align with the resume description: {specifications}. Feedback: {critique}. Output only the query.",
      "output_key": "current_search_query"
    },
    {
      "id": "searcher",
      "type": "search_tool",
      "input_key": "current_search_query",
      "output_key": "job_listings"
    },
    {
      "id": "validator",
      "type": "llm_json",
      "prompt": "Client description: {specifications}. Jobs: {job_listings}. Validate each job against the client description. Return JSON with 'passed_ids' (list) and 'feedback' (string).",
      "output_mapping": {
        "passed_ids": "valid_results",
        "feedback": "critique"
      }
    }
  ],
  "edges": [
    ["optimizer", "searcher"],
    ["searcher", "validator"]
  ],
  "conditional_edges": [
    {
      "source": "validator",
      "condition": "len(state['valid_results']) < 5 and state['iterations'] < 3",
      "mapping": { "true": "optimizer", "false": "END" }
    }
  ],
  "entry_point": "optimizer"
}
